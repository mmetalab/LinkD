# LinkD Agent API Keys
# Copy this file to .env and fill in your keys.
# Only the provider you use needs to be set.

# OpenAI (for GPT-4o, GPT-4o-mini, etc.)
OPENAI_API_KEY=

# Google Gemini
GOOGLE_API_KEY=

# Anthropic Claude
ANTHROPIC_API_KEY=

# Free Gemini key for server-side "no API key" mode
# Get a free key at https://aistudio.google.com/apikey
GEMINI_FREE_KEY=
